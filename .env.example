# --- Server ---
NODE_ENV=development
PORT=4000

# The frontend's public origin — used to validate CSRF (Origin/Referer must
# match) and to build invite URLs. The frontend proxies requests here via
# Next.js rewrites, which forwards the browser's real Origin/Referer
# headers through unchanged, so this still works exactly as if everything
# were one project.
APP_URL=http://localhost:3000
APP_NAME=Timeline

# The standalone admin panel's own origin (separate project, separate dev
# server) — same CSRF Origin/Referer check as APP_URL above, just for a
# second allowed origin.
ADMIN_APP_URL=http://localhost:5174

# --- MongoDB Atlas ---
# Create a free cluster at https://cloud.mongodb.com, add a database user,
# allow your IP (or 0.0.0.0/0 for development), then paste the connection string here.
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/timeline?retryWrites=true&w=majority

# --- Auth secrets ---
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# JWT_ACCESS_SECRET must match the frontend's .env value exactly (see its
# .env.example) — the frontend's middleware verifies this project's tokens.
JWT_ACCESS_SECRET=replace-with-a-64-byte-random-hex-string
JWT_REFRESH_SECRET=replace-with-a-different-64-byte-random-hex-string
MEDIA_TOKEN_SECRET=replace-with-a-third-64-byte-random-hex-string

# Encrypts payment gateway secrets (Razorpay key_secret, webhook secrets,
# etc.) at rest. Must be exactly 32 bytes hex-encoded (64 hex chars).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SETTINGS_ENCRYPTION_KEY=replace-with-a-32-byte-random-hex-string

# --- reCAPTCHA (optional) ---
# Verifies login/register submissions with Google reCAPTCHA v3. Leave unset
# to skip verification entirely — nothing else changes. Get keys at
# https://www.google.com/recaptcha/admin (choose v3). The site key is public
# and goes in the frontend's .env as NEXT_PUBLIC_RECAPTCHA_SITE_KEY.
RECAPTCHA_SECRET_KEY=

# --- Bootstrap ---
# The email that will automatically be promoted to platform superadmin
# the first time it registers (see scripts/seedSuperAdmin.js).
SUPERADMIN_EMAIL=you@example.com

# --- Storage ---
# "local" (default, self-hosted disk under STORAGE_LOCAL_PATH) or "s3"
# (AWS S3 / Cloudflare R2 / MinIO — any S3-compatible endpoint).
STORAGE_DRIVER=local
# Must be an absolute path (or a shared Docker volume — see
# docker-compose.yml in the frontend project) rather than a relative one:
# this project and its worker process (scripts/worker.js) each have their
# own working directory, and a relative path would silently resolve to two
# different, disconnected directories.
STORAGE_LOCAL_PATH=/absolute/path/to/storage

# Only needed when STORAGE_DRIVER=s3
S3_BUCKET=
S3_REGION=auto
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=false

# --- Uploads ---
MAX_UPLOAD_SIZE_MB=500

# --- Worker (scripts/worker.js) ---
WORKER_POLL_INTERVAL_MS=15000
WORKER_TRASH_SWEEP_CRON=0 3 * * *
